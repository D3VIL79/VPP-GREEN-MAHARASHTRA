# ═══════════════════════════════════════════════════════════
# VPP Green Maharashtra — Root .gitignore
# ═══════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
*.egg-info/
dist/
build/
.eggs/

# ── Node.js ──
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──
.next/
out/

# ── Environment / Secrets ──
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Build artifacts ──
*.tsbuildinfo
next-env.d.ts
/coverage

# ── Debug logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Agent / AI assistant artifacts ──
.agent/
.agents/
scratch/
skills-lock.json
CLAUDE.md
AGENTS.md

# ── Vercel ──
.vercel

# ── Empty dataset folder ──
Tree_Species_Dataset/

# ── Temporary / generated ──
combined.md
unicode_check.txt

# ── SQL and database seeds ──
supabase_seeder/
*.sql

# ── Large training datasets ──
/data/
vpp-green/ai-backend/data/

# ── Training pipeline and reports ──
/vpp_green_pipeline.py
/results/
vpp-green/ai-backend/vpp_green_pipeline.py
vpp-green/ai-backend/results/

# ── Root ML models (duplicate of vpp-green/ai-backend/models) ──
/models/


